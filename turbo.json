{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "//#lint": {
      "inputs": [
        "**/*.ts",
        "!.agents/skills/**/*.ts",
        "!packages/web/dist/**/*.ts",
        "!node_modules/**/*.ts",
        "!packages/web/dist/**/*.ts"
      ],
      "cache": true
    },
    "web#build": {
      "cache": true,
      "outputs": ["./dist/**/*"]
    },
    "//#test:unit": {
      "cache": true
    },
    "//#knip": {
      "cache": true
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": true
    },
    "//#test:coverage": {
      "outputs": ["./coverage"],
      "cache": true
    },
    "//#test:merge-coverage": {
      "dependsOn": ["//#test:coverage"],
      "inputs": ["./coverage"],
      "outputs": ["./coverage-merged"],
      "cache": true
    },
    "//#test:check-coverage": {
      "dependsOn": ["test:merge-coverage"],
      "cache": true
    }
  }
}
