{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": ["NODE_ENV"],
  "globalDependencies": ["tsconfig.json"],
  "cacheMaxSize": "1GB",
  "tasks": {
    "//#lint": {
      "inputs": [
        "**/*.ts",
        "!.agents/skills/**/*.ts",
        "!packages/web/dist/**/*.js",
        "!node_modules/**/*.ts"
      ],
      "cache": true
    },
    "//#knip": {
      "cache": true
    },
    "test:coverage": {
      "cache": true
    },
    "//#test:merge-coverage": {
      "dependsOn": ["^test:coverage"],
      "inputs": ["./coverage"],
      "outputs": ["./coverage-merged"],
      "cache": true
    },
    "//#test:check-coverage": {
      "dependsOn": ["//#test:merge-coverage"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": true
    },
    "test:unit": {
      "cache": true
    },
    "web#build": {
      "cache": true,
      "outputs": ["./dist/**/*"]
    },
    "web#dev": {
      "cache": false,
      "persistent": true
    },
    "server#dev": {
      "cache": false,
      "persistent": true
    },
    "web#test:watch": {
      // "dependsOn": ["web#test:watch"],
      "cache": false,
      "persistent": true
    },
    "server#test:watch": {
      "cache": false,
      "persistent": true
    },
    "shared#test:watch": {
      "cache": false,
      "persistent": true
    },
    "api-client#test:watch": {
      "cache": false,
      "persistent": true
    }
  }
}
