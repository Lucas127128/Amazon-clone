{
  "name": "amazon-clone",
  "type": "module",
  "imports": {
    "#root/*": "./*",
    "#data/*": "./shared/src/data/*",
    "#utils/*": "./shared/src/utils/*"
  },
  "scripts": {
    "test:bun": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun test --watch --max-concurrency 100",
    "test:ci": "NODE_TLS_REJECT_UNAUTHORIZED=0 FORCE_COLOR=1 bun test --max-concurrency 100",
    "test:api": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun test ./tests/normal/server/api --watch --max-concurrency 100",
    "test:e2e": "NODE_TLS_REJECT_UNAUTHORIZED=0 playwright test --trace on -c ./config/playwright.config.ts",
    "test:vitest": "vitest -c ./config/vitest.config.ts",
    "test": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun run --parallel test:vitest test:bun",
    "build": "vite build -c ./config/vite.config.ts",
    "preview": "vite -c ./config/vite.config.ts",
    "inspect": "node-modules-inspector",
    "remove-build-cache": " find . -name '*.bun-build' -type f -delete ",
    "exec-api": "./api",
    "api": "bun run ./config/bun-build.ts && bun run --parallel exec-api remove-build-cache",
    "api:dev": "bun run --watch ./server/src/api/server.ts",
    "lint": "bunx --bun oxlint -c ./oxlint.config.ts",
    "fmt": "oxfmt",
    "knip": "knip -c ./config/knip.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/openapi": "^1.4.14",
    "@orama/orama": "^3.1.18",
    "@preact/signals-core": "^1.14.1",
    "@preact/signals-debug": "^1.4.2",
    "@valibot/to-json-schema": "^1.6.0",
    "better-all": "^0.0.7",
    "dompurify": "^3.3.3",
    "elysia": "^1.4.28",
    "elysia-local-https": "^1.0.2",
    "fp-ts": "^2.16.11",
    "nanoid": "^5.1.7",
    "temporal-polyfill-lite": "^0.3.3",
    "ts-pattern": "^5.9.0",
    "type-fest": "^5.5.0",
    "typed-query-selector": "^2.12.1",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@playwright/test": "^1.59.0",
    "@preact/eslint-plugin-signals": "^0.2.0",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/bun": "^1.3.11",
    "@types/trusted-types": "^2.0.7",
    "@vitejs/devtools": "^0.1.11",
    "@vitest/browser-preview": "^4.1.2",
    "eslint-plugin-depend": "^1.5.0",
    "husky": "^9.1.7",
    "knip": "^6.1.1",
    "node-modules-inspector": "^1.4.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "playwright": "^1.59.0",
    "rollup-plugin-bundle-stats": "^4.22.0",
    "sharp": "^0.34.5",
    "vite": "^8.0.3",
    "vite-plugin-html-minifier": "^1.0.5",
    "vite-plugin-purgecss": "^0.2.13",
    "vitest": "^4.1.2"
  }
}
