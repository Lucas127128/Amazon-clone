{
  "name": "amazon-clone",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "temporal-polyfill-lite": "^0.3.3",
      "@preact/signals-core": "^1.14.1",
      "valibot": "^1.3.1"
    }
  },
  "type": "module",
  "scripts": {
    "inspect": "node-modules-inspector",
    "lint": "bunx --bun oxlint -c ./oxlint.config.ts",
    "fmt": "oxfmt",
    "dev": "bun run --parallel --elide-lines 10000 -F '*' dev",
    "test": "bun run --elide-lines 10000 -F tests test:bun",
    "start": "bun run --elide-lines 10000 -F server start"
  },
  "devDependencies": {
    "@preact/eslint-plugin-signals": "^0.2.0",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/bun": "^1.3.11",
    "@types/trusted-types": "^2.0.7",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "knip": "^6.2.0",
    "node-modules-inspector": "^1.4.2",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "vite": "^8.0.3"
  }
}
