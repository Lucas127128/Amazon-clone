{
  "name": "amazon-clone",
  "type": "module",
  "imports": {
    "#root/*": "./*",
    "#data/*": "./shared/src/data"
  },
  "scripts": {
    "allow-certs": "export NODE_TLS_REJECT_UNAUTHORIZED=0",
    "test:bun": "NODE_TLS_REJECT_UNAUTHORIZED=0 FORCE_COLOR=1 bun test --watch --max-concurrency 100",
    "test:ci": "NODE_TLS_REJECT_UNAUTHORIZED=0 FORCE_COLOR=1 bun test --max-concurrency 100",
    "test:e2e": "bun run allow-certs && playwright test --trace on -c ./config/playwright.config.ts",
    "test:vitest": "vitest -c ./config/vitest.config.ts",
    "test": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun run --parallel test:vitest test:bun",
    "build": "vite build -c ./config/vite.config.ts",
    "preview": "vite -c ./config/vite.config.ts",
    "inspect": "node-modules-inspector",
    "build:backend": "bun build --compile --minify --sourcemap --bytecode --format='esm' ./server/src/api/index.ts ",
    "remove-build-cache": " find . -name '*.bun-build' -type f -delete ",
    "exec-api": "./api",
    "api": "bun run --parallel build:backend allow-certs && bun run --parallel exec-api remove-build-cache",
    "api:dev": "bun run ./server/src/api/server.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "dompurify": "^3.3.2",
    "elysia": "^1.4.27",
    "elysia-local-https": "^1.0.2",
    "idb-keyval": "^6.2.2",
    "minisearch": "^7.2.0",
    "nanoid": "^5.1.6",
    "temporal-polyfill-lite": "^0.2.3",
    "ts-pattern": "^5.9.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.3",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.10",
    "@types/trusted-types": "^2.0.7",
    "@vitejs/devtools": "^0.0.0-alpha.33",
    "@vitest/browser-preview": "^4.0.18",
    "axios": "^1.13.6",
    "bun-types": "1.3.5",
    "fake-indexeddb": "^6.2.5",
    "knip": "^5.86.0",
    "node-modules-inspector": "^1.4.2",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.12.2",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "type-fest": "^5.4.4",
    "unplugin-turbo-console": "^2.3.0",
    "vite": "^8.0.0-beta.16",
    "vite-plugin-html-minifier": "^1.0.5",
    "vitest": "^4.0.18"
  }
}
