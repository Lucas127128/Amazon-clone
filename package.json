{
  "name": "amazon-clone",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@vitest/ui": "^4.1.8",
      "happy-dom": "^20.9.0",
      "temporal-polyfill-lite": "^0.4.0",
      "valibot": "^1.4.1",
      "vite": "^8.0.16",
      "vitest": "^4.1.8",
      "effect": "^4.0.0-beta.75"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "bunx -b oxlint -c ./oxlint.config.ts",
    "fmt": "oxfmt",
    "dev": "turbo run web#dev server#dev --ui tui",
    "test": "turbo run web#test:watch server#test:watch shared#test:watch api-client#test:watch --ui tui",
    "test:coverage": "turbo run test:coverage",
    "test:merge-coverage": "vitest-coverage-merge coverage/* -o coverage-merged",
    "test:check-coverage": "nyc check-coverage --lines 90 --functions 90 --branches 80 --statements 90 --temp-dir=./coverage-merged",
    "test:unit": "turbo run test:unit",
    "test:api": "bun run test ./normal/server/api --watch",
    "start": "bun run --cwd ./packages/server start",
    "build": "turbo run build",
    "knip": "knip-bun",
    "pre-commit": "bunx turbo run lint knip test:unit"
  },
  "devDependencies": {
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.14",
    "@types/trusted-types": "^2.0.7",
    "@vitest/coverage-istanbul": "4.1.8",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-turbo": "^2.9.16",
    "eslint-plugin-typed-rocks": "^1.0.8",
    "husky": "^9.1.7",
    "knip": "^6.15.0",
    "nyc": "^18.0.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.9.16",
    "vite": "catalog:",
    "vitest-coverage-merge": "^0.2.0"
  },
  "packageManager": "bun@1.3.13",
  "patchedDependencies": {
    "comptime@0.1.0": "patches/comptime@0.1.0.patch"
  }
}
