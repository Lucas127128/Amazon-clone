{
  "name": "amazon-clone",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "temporal-polyfill-lite": "^0.3.4",
      "valibot": "^1.3.1",
      "vite": "^8.0.8",
      "@tanstack/store": "^0.11.0"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "bunx -b oxlint -c ./oxlint.config.ts",
    "fmt": "oxfmt",
    "dev": "bun run --parallel --elide-lines 10000 -F '*' dev",
    "test": "bun run --cwd ./packages/tests test",
    "start": "bun run --cwd ./packages/server start",
    "build": "bun run --cwd ./packages/web build"
  },
  "devDependencies": {
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/bun": "^1.3.12",
    "@types/trusted-types": "^2.0.7",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "vite": "catalog:"
  }
}
