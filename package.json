{
  "name": "amazon-clone",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@vitest/ui": "^4.1.7",
      "happy-dom": "^20.9.0",
      "temporal-polyfill-lite": "^0.4.0",
      "valibot": "^1.4.1",
      "vite": "^8.0.14",
      "vitest": "^4.1.7"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "bunx -b oxlint -c ./oxlint.config.ts",
    "fmt": "oxfmt",
    "dev": "bun run --parallel --elide-lines 10000 -F '*' dev",
    "test": "bun run --parallel --elide-lines 10000 -F '*' test:watch",
    "test:coverage": "bun run --parallel --elide-lines 10000 -F '*' test:coverage",
    "test:merge-coverage": "vitest-coverage-merge coverage/* -o coverage-merged",
    "test:check-coverage": "nyc check-coverage --lines 90 --functions 90 --branches 80 --statements 90 --temp-dir=./coverage-merged",
    "test:unit": "bun run --parallel -F '*' --elide-lines 10000 test:unit",
    "test:api": "bun run test ./normal/server/api --watch",
    "start": "bun run --cwd ./packages/server start",
    "build": "bun run --cwd ./packages/web build",
    "knip": "knip-bun",
    "pre-commit": "bunx turbo lint knip test:unit"
  },
  "devDependencies": {
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/bun": "^1.3.14",
    "@types/trusted-types": "^2.0.7",
    "@vitest/coverage-istanbul": "4.1.7",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-turbo": "^2.9.14",
    "husky": "^9.1.7",
    "knip": "^6.14.2",
    "nyc": "^18.0.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.9.14",
    "vite": "^8.0.14",
    "vitest-coverage-merge": "^0.2.0"
  },
  "packageManager": "bun@1.3.13",
  "patchedDependencies": {
    "comptime@0.1.0": "patches/comptime@0.1.0.patch"
  }
}
