{
  "name": "amazon-clone",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@tanstack/store": "^0.11.0",
      "@vitest/ui": "^4.1.5",
      "happy-dom": "^20.9.0",
      "temporal-polyfill-lite": "^0.3.5",
      "valibot": "^1.3.1",
      "vite": "^8.0.10",
      "vitest": "^4.1.5"
    }
  },
  "type": "module",
  "imports": {
    "#testData/*": "./testData/*"
  },
  "scripts": {
    "lint": "bunx -b oxlint -c ./oxlint.config.ts",
    "fmt": "oxfmt",
    "dev": "bun run --parallel --elide-lines 10000 -F '*' dev",
    "test": "bunx -b vitest",
    "test:ci": "bun run test -w=false",
    "test:unit": "bun run test -w false --project happy-dom --project bun --exclude '**/*/scripts/data/orders.test.ts' ",
    "test:api": "bun run test ./normal/server/api --watch",
    "start": "bun run --cwd ./packages/server start",
    "build": "bun run --cwd ./packages/web build"
  },
  "devDependencies": {
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/bun": "^1.3.13",
    "@types/trusted-types": "^2.0.7",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "happy-dom": "catalog:",
    "husky": "^9.1.7",
    "knip": "^6.6.3",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "server": "workspace:*",
    "shared": "workspace:*",
    "temporal-polyfill-lite": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
