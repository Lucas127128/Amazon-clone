{
  "name": "amazon-clone",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@vitest/ui": "^4.1.6",
      "happy-dom": "^20.9.0",
      "temporal-polyfill-lite": "^0.3.5",
      "valibot": "^1.3.1",
      "vite": "^8.0.10",
      "vitest": "^4.1.6"
    }
  },
  "type": "module",
  "scripts": {
    "lint": "bunx -b oxlint -c ./oxlint.config.ts",
    "fmt": "oxfmt",
    "dev": "bun run --parallel --elide-lines 10000 -F '*' dev",
    "test": "bunx -b vitest -c ./config/vitest.config.ts",
    "test:coverage": "bun run test --coverage -w false",
    "test:unit": "bun run test -w false --project happy-dom --project bun --exclude **/*/scripts/data/orders.test.ts --exclude **/*/paymentSummary.test.ts ",
    "test:api": "bun run test ./normal/server/api --watch",
    "start": "bun run --cwd ./packages/server start",
    "build": "bun run --cwd ./packages/web build",
    "knip": "knip",
    "pre-commit": "bunx turbo lint knip test:unit"
  },
  "devDependencies": {
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/bun": "^1.3.13",
    "@types/trusted-types": "^2.0.7",
    "@vitest/coverage-istanbul": "4.1.6",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-turbo": "^2.9.12",
    "happy-dom": "catalog:",
    "husky": "^9.1.7",
    "knip": "^6.11.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "server": "workspace:*",
    "shared": "workspace:*",
    "temporal-polyfill-lite": "catalog:",
    "turbo": "^2.9.12",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
