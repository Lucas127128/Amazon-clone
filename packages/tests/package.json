{
  "name": "tests",
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#testData/*": "./testData/*"
  },
  "scripts": {
    "test": "bunx -b vitest",
    "test:ci": "bun run test -w=false",
    "test:unit": "bun run test --project happy-dom --project bun --exclude '**/*/scripts/data/orders.test.ts' ",
    "test:api": "bun run test ./normal/server/api --watch",
    "test:e2e": "NODE_TLS_REJECT_UNAUTHORIZED=0 playwright test --trace on"
  },
  "dependencies": {
    "@tanstack/store": "catalog:",
    "server": "workspace:*",
    "shared": "workspace:*",
    "temporal-polyfill-lite": "catalog:",
    "web": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/browser-preview": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "vitest": "^4.1.5"
  }
}
