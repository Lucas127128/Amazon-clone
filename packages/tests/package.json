{
  "name": "tests",
  "version": "1.0.0",
  "scripts": {
    "test:bun": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun test --watch",
    "test:ci": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun test",
    "test:unit": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun test ./normal/shared ./normal/web",
    "test:api": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun test ./normal/server/api --watch",
    "test:e2e": "NODE_TLS_REJECT_UNAUTHORIZED=0 playwright test --trace on",
    "test:vitest": "vitest",
    "test": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun run --parallel test:vitest test:bun"
  },
  "dependencies": {
    "server": "workspace:*",
    "shared": "workspace:*",
    "temporal-polyfill-lite": "^0.3.3",
    "valibot": "^1.3.1",
    "web": "workspace:*"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@playwright/test": "^1.58.2",
    "@vitest/browser-preview": "^4.1.2",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5"
  }
}
