{
  "name": "tests",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "bunx --bun vitest",
    "test:ci": "bun run test -w=false",
    "test:unit": "bun run test ./normal/shared ./normal/web",
    "test:api": "bun run test ./normal/server/api --watch",
    "test:e2e": "NODE_TLS_REJECT_UNAUTHORIZED=0 playwright test --trace on"
  },
  "dependencies": {
    "server": "workspace:*",
    "shared": "workspace:*",
    "temporal-polyfill-lite": "catalog:",
    "valibot": "catalog:",
    "web": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/browser-preview": "^4.1.2",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "vitest": "^4.1.2"
  }
}
