{
  "name": "web",
  "version": "1.0.0",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#pages/*": "./src/scripts/pages/*",
    "#utils/*": "./src/scripts/utils/*",
    "#data/*": "./src/scripts/data/*"
  },
  "scripts": {
    "build": "NODE_TLS_REJECT_UNAUTHORIZED=0 bunx -b vite build",
    "dev": "vite",
    "test": "bunx -b vitest -w false",
    "test:watch": "bunx -b vitest -w",
    "test:coverage": "bunx -b vitest -w false --coverage",
    "test:unit": "bun run test --exclude **/*/scripts/data/orders.test.ts --exclude **/*/paymentSummary.test.ts "
  },
  "dependencies": {
    "@nanostores/persistent": "^1.3.4",
    "@orama/highlight": "^0.1.9",
    "@tanstack/pacer-lite": "^0.2.2",
    "api-client": "workspace:*",
    "dompurify": "^3.4.6",
    "nanostores": "^1.3.0",
    "shared": "workspace:*",
    "temporal-polyfill-lite": "catalog:",
    "typed-query-selector": "^2.12.1",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@vitejs/devtools": "^0.2.0",
    "@vitest/ui": "catalog:",
    "comptime": "^0.1.0",
    "happy-dom": "catalog:",
    "html-minifier-next": "^6.2.7",
    "sonda": "^0.11.1",
    "testdata": "workspace:*",
    "vite": "catalog:",
    "vite-plugin-html-minifier": "^1.0.5",
    "vite-plugin-purgecss": "^0.2.13",
    "vitest": "catalog:"
  }
}
