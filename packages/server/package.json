{
  "name": "server",
  "version": "1.0.0",
  "exports": {
    ".": "./src/api/server.ts",
    "./rawProducts": "./src/api/rawProducts.json",
    "./clothing": "./src/api/clothing.json"
  },
  "scripts": {
    "remove-build-cache": " find . -name '*.bun-build' -type f -delete ",
    "exec-api": "./api",
    "api": "bun run ./bun-build.ts && bun run --parallel exec-api remove-build-cache",
    "api:dev": "bun run --watch ./src/api/server.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@orama/orama": "^3.1.18",
    "@valibot/to-json-schema": "^1.6.0",
    "elysia": "^1.4.28",
    "elysia-local-https": "^1.0.2",
    "nanoid": "^5.1.7",
    "shared": "workspace:*",
    "temporal-polyfill-lite": "^0.3.3",
    "ts-pattern": "^5.9.0",
    "type-fest": "^5.5.0",
    "valibot": "^1.3.1"
  }
}
