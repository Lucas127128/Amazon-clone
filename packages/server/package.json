{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/api/server.ts",
    "./rawProducts": "./src/api/rawProducts.json",
    "./clothing": "./src/api/clothing.json"
  },
  "scripts": {
    "remove-build-cache": " find . -name '*.bun-build' -type f -delete ",
    "exec-api": "PROD=true ./api",
    "code-sign": "codesign --remove-signature ./api && codesign --force --sign - ./api",
    "start": "bun run ./bun-build.ts && bun run code-sign && bun run --parallel exec-api remove-build-cache",
    "dev": "DEV=true bun run --watch ./src/api/server.ts",
    "load-test": "bombardier --insecure -c 1200 -n 500000 -t 0.5s -l https://localhost:8080/index.html"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@orama/orama": "^3.1.18",
    "@valibot/to-json-schema": "^1.6.0",
    "elysia": "^1.4.28",
    "elysia-local-https": "^1.0.2",
    "evlog": "^2.13.0",
    "nanoid": "^5.1.9",
    "shared": "workspace:*",
    "temporal-polyfill-lite": "catalog:",
    "ts-pattern": "^5.9.0",
    "type-fest": "^5.6.0",
    "valibot": "catalog:"
  }
}
