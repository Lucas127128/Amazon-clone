{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#testData/*": "./tests/testData/*"
  },
  "exports": {
    ".": "./src/api/server.ts",
    "./rawProducts": "./rawData/rawProducts.json",
    "./clothing": "./rawData/clothing.json",
    "./orderService": "./src/api/orders/service.ts",
    "./productService": "./src/api/products/service.ts"
  },
  "scripts": {
    "start": "bun ./start-server.ts",
    "dev": "DEV=true bun run --watch ./src/api/server.ts",
    "load-test": "bombardier --insecure -c 1200 -n 500000 -t 0.5s -l https://localhost:8080/index.html"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@orama/orama": "^3.1.18",
    "@valibot/to-json-schema": "^1.6.0",
    "elysia": "^1.4.28",
    "elysia-local-https": "^1.0.2",
    "evlog": "^2.13.0",
    "nanoid": "^5.1.9",
    "shared": "workspace:*",
    "temporal-polyfill-lite": "catalog:",
    "ts-pattern": "^5.9.0",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.5",
    "happy-dom": "^20.9.0",
    "vitest": "^4.1.5"
  }
}
