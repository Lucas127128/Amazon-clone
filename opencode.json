{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "git *": "deny",
      "rm *": "deny",
      "chmod *": "deny",
      "grep *": "allow",
      "Grep *": "allow",
      "ls *": "allow",
      "cd *": "allow",
      "bun *": "allow",
      "bunx *": "allow",
      "cat *": "allow",
      "find *": "allow",
      "head *": "allow"
    },
    "edit": "allow",
    "glob": "allow",
    "read": "allow"
  }
}
